# BPF core
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_JIT_DEFAULT_ON=y
CONFIG_BPF_EVENTS=y
CONFIG_BPF_STREAM_PARSER=y
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y
CONFIG_CGROUP_BPF=y
CONFIG_XDP_SOCKETS=y
CONFIG_XDP_SOCKETS_DIAG=y

# BTF / CO-RE
CONFIG_DEBUG_INFO=y
# CONFIG_DEBUG_INFO_NONE is not set
# CONFIG_DEBUG_INFO_REDUCED is not set
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y
CONFIG_DEBUG_INFO_BTF=y
CONFIG_DEBUG_INFO_BTF_MODULES=y

# ftrace / fentry / fexit / kprobe
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_GRAPH_TRACER=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_DYNAMIC_FTRACE_WITH_REGS=y
CONFIG_DYNAMIC_FTRACE_WITH_DIRECT_CALLS=y
CONFIG_FPROBE=y
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_UPROBES=y
CONFIG_UPROBE_EVENTS=y
CONFIG_FTRACE_SYSCALLS=y
# Disable ftrace sub-options for test/startup overhead to avoid oldconfig prompts
# CONFIG_BOOTTIME_TRACING is not set
# CONFIG_FTRACE_STARTUP_TEST is not set
# CONFIG_FTRACE_RECORD_RECURSION is not set
# CONFIG_FTRACE_SORT_STARTUP_TEST is not set
# CONFIG_FTRACE_VALIDATE_RCU_IS_WATCHING is not set
# CONFIG_KPROBES_SANITY_TEST is not set
# CONFIG_FUNCTION_PROFILER is not set
# CONFIG_STACK_TRACER is not set
# CONFIG_IRQSOFF_TRACER is not set
# CONFIG_PREEMPT_TRACER is not set
# CONFIG_SCHED_TRACER is not set
# CONFIG_HWLAT_TRACER is not set
# CONFIG_OSNOISE_TRACER is not set
# CONFIG_TIMERLAT_TRACER is not set
# CONFIG_MMIOTRACE is not set
# CONFIG_BLK_DEV_IO_TRACE is not set
# CONFIG_HIST_TRIGGERS is not set
# CONFIG_TRACE_BRANCH_PROFILING is not set
# CONFIG_RING_BUFFER_BENCHMARK is not set
# CONFIG_RING_BUFFER_VALIDATE_TIME_DELTAS is not set
# CONFIG_RING_BUFFER_STARTUP_TEST is not set
# CONFIG_RV is not set
# CONFIG_FPROBE_EVENTS is not set
# CONFIG_BPF_KPROBE_OVERRIDE is not set
# CONFIG_USER_EVENTS is not set
# CONFIG_TRACEPOINT_BENCHMARK is not set
# CONFIG_TRACING_MAP is not set

# GCC plugins / other options that may trigger NEW prompts if enabled
# CONFIG_GCC_PLUGINS is not set
# CONFIG_KASAN is not set
# CONFIG_KCSAN is not set
# CONFIG_LIVEPATCH is not set
# CONFIG_BPF_JIT_TEST is not set
# CONFIG_TEST_BPF is not set
# CONFIG_BPF_PRELOAD is not set
# CONFIG_NET_DROP_MONITOR is not set

# TC / ingress
CONFIG_NET_SCHED=y
CONFIG_NET_SCH_INGRESS=y
CONFIG_NET_CLS_ACT=y
CONFIG_NET_CLS_BPF=y
CONFIG_NET_ACT_BPF=y
CONFIG_LWTUNNEL=y
CONFIG_LWTUNNEL_BPF=y
